{
  "name": "jgrants-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch",
    "dev:electron": "wait-on tcp:5174 file:dist-electron/main/index.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "ci:verify": "npm run typecheck && npm run test && npm run build",
    "e2e": "npm run build && node --test tests/e2e/smoke.e2e.test.cjs",
    "e2e:ci": "xvfb-run -a npm run e2e",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "npm run build:main && node --test tests/csv-core.test.cjs tests/favorites-store-core.test.cjs tests/ipc-handlers.test.cjs tests/jgrants-client.test.cjs tests/token-store-core.test.cjs tests/logger-core.test.cjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.51.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "jp.edamoto.jgrantsdesktop",
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "directories": { "buildResources": "build" },
    "mac": {
      "target": ["dmg", "zip"],
      "hardenedRuntime": true
    },
    "win": {
      "target": ["nsis", "zip"]
    }
  }
}
